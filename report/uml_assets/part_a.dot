digraph PartA {
  graph [rankdir=TB, bgcolor="white", label="Part A - Factory Method Pattern", labelloc=t, fontsize=20, fontname="Arial"];
  node [shape=record, fontname="Arial", fontsize=10, style="filled", fillcolor="#f8f8f8", color="#333333"];
  edge [fontname="Arial", fontsize=9, color="#333333"];

  Exam [label="{\<\<interface\>\>\nExam|+ getType(): String\l+ displayInfo(): void\l}"];
  ExamFactory [label="{\<\<abstract\>\>\nExamFactory|+ createExam(): Exam\l}"];

  PracticeQuiz [label="{PracticeQuiz|+ getType(): String\l+ displayInfo(): void\l}"];
  MidtermExam [label="{MidtermExam|+ getType(): String\l+ displayInfo(): void\l}"];
  FinalExam [label="{FinalExam|+ getType(): String\l+ displayInfo(): void\l}"];

  PracticeQuizFactory [label="{PracticeQuizFactory|+ createExam(): Exam\l}"];
  MidtermExamFactory [label="{MidtermExamFactory|+ createExam(): Exam\l}"];
  FinalExamFactory [label="{FinalExamFactory|+ createExam(): Exam\l}"];

  PracticeQuiz -> Exam [arrowhead=empty, style=dashed];
  MidtermExam -> Exam [arrowhead=empty, style=dashed];
  FinalExam -> Exam [arrowhead=empty, style=dashed];

  PracticeQuizFactory -> ExamFactory [arrowhead=empty];
  MidtermExamFactory -> ExamFactory [arrowhead=empty];
  FinalExamFactory -> ExamFactory [arrowhead=empty];

  PracticeQuizFactory -> PracticeQuiz [style=dashed, label="creates"];
  MidtermExamFactory -> MidtermExam [style=dashed, label="creates"];
  FinalExamFactory -> FinalExam [style=dashed, label="creates"];
}
