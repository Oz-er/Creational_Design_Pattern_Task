digraph PartB {
  graph [rankdir=TB, bgcolor="white", label="Part B - Abstract Factory Pattern", labelloc=t, fontsize=20, fontname="Arial"];
  node [shape=record, fontname="Arial", fontsize=9, style="filled", fillcolor="#f8f8f8", color="#333333"];
  edge [fontname="Arial", fontsize=8, color="#333333"];

  Question [label="{\<\<interface\>\>\nQuestion|+ getType(): String\l+ getPoints(): int\l+ getDifficulty(): String\l}"];
  QuestionRenderer [label="{\<\<interface\>\>\nQuestionRenderer|+ render(question: Question): void\l}"];
  QuestionEvaluator [label="{\<\<interface\>\>\nQuestionEvaluator|+ evaluate(question: Question, answer: String): int\l}"];
  QuestionFactory [label="{\<\<interface\>\>\nQuestionFactory|+ createQuestion(): Question\l+ createRenderer(): QuestionRenderer\l+ createEvaluator(): QuestionEvaluator\l}"];

  MCQQuestion [label="{MCQQuestion|- text: String\l- points: int\l- difficulty: String\l+ getType(): String\l+ getText(): String\l+ getPoints(): int\l+ getDifficulty(): String\l}"];
  TrueFalseQuestion [label="{TrueFalseQuestion|- text: String\l- points: int\l- difficulty: String\l+ getType(): String\l+ getText(): String\l+ getPoints(): int\l+ getDifficulty(): String\l}"];
  EssayQuestion [label="{EssayQuestion|- text: String\l- points: int\l- difficulty: String\l+ getType(): String\l+ getText(): String\l+ getPoints(): int\l+ getDifficulty(): String\l}"];
  ProgrammingQuestion [label="{ProgrammingQuestion|- text: String\l- points: int\l- difficulty: String\l+ getType(): String\l+ getText(): String\l+ getPoints(): int\l+ getDifficulty(): String\l}"];

  MCQRenderer [label="{MCQRenderer|+ render(question: Question): void\l}"];
  TrueFalseRenderer [label="{TrueFalseRenderer|+ render(question: Question): void\l}"];
  EssayRenderer [label="{EssayRenderer|+ render(question: Question): void\l}"];
  ProgrammingRenderer [label="{ProgrammingRenderer|+ render(question: Question): void\l}"];

  MCQEvaluator [label="{MCQEvaluator|+ evaluate(question: Question, answer: String): int\l}"];
  TrueFalseEvaluator [label="{TrueFalseEvaluator|+ evaluate(question: Question, answer: String): int\l}"];
  EssayEvaluator [label="{EssayEvaluator|+ evaluate(question: Question, answer: String): int\l}"];
  ProgrammingEvaluator [label="{ProgrammingEvaluator|+ evaluate(question: Question, answer: String): int\l}"];

  MCQFactory [label="{MCQFactory|- source: QuestionSource\l+ createQuestion(): Question\l+ createRenderer(): QuestionRenderer\l+ createEvaluator(): QuestionEvaluator\l}"];
  TrueFalseFactory [label="{TrueFalseFactory|- source: QuestionSource\l+ createQuestion(): Question\l+ createRenderer(): QuestionRenderer\l+ createEvaluator(): QuestionEvaluator\l}"];
  EssayFactory [label="{EssayFactory|- source: QuestionSource\l+ createQuestion(): Question\l+ createRenderer(): QuestionRenderer\l+ createEvaluator(): QuestionEvaluator\l}"];
  ProgrammingFactory [label="{ProgrammingFactory|- source: QuestionSource\l+ createQuestion(): Question\l+ createRenderer(): QuestionRenderer\l+ createEvaluator(): QuestionEvaluator\l}"];

  MCQQuestion -> Question [arrowhead=empty, style=dashed];
  TrueFalseQuestion -> Question [arrowhead=empty, style=dashed];
  EssayQuestion -> Question [arrowhead=empty, style=dashed];
  ProgrammingQuestion -> Question [arrowhead=empty, style=dashed];

  MCQRenderer -> QuestionRenderer [arrowhead=empty, style=dashed];
  TrueFalseRenderer -> QuestionRenderer [arrowhead=empty, style=dashed];
  EssayRenderer -> QuestionRenderer [arrowhead=empty, style=dashed];
  ProgrammingRenderer -> QuestionRenderer [arrowhead=empty, style=dashed];

  MCQEvaluator -> QuestionEvaluator [arrowhead=empty, style=dashed];
  TrueFalseEvaluator -> QuestionEvaluator [arrowhead=empty, style=dashed];
  EssayEvaluator -> QuestionEvaluator [arrowhead=empty, style=dashed];
  ProgrammingEvaluator -> QuestionEvaluator [arrowhead=empty, style=dashed];

  MCQFactory -> QuestionFactory [arrowhead=empty, style=dashed];
  TrueFalseFactory -> QuestionFactory [arrowhead=empty, style=dashed];
  EssayFactory -> QuestionFactory [arrowhead=empty, style=dashed];
  ProgrammingFactory -> QuestionFactory [arrowhead=empty, style=dashed];

  MCQFactory -> MCQQuestion [style=dashed, label="creates via source"];
  MCQFactory -> MCQRenderer [style=dashed, label="creates"];
  MCQFactory -> MCQEvaluator [style=dashed, label="creates"];

  TrueFalseFactory -> TrueFalseQuestion [style=dashed, label="creates via source"];
  TrueFalseFactory -> TrueFalseRenderer [style=dashed, label="creates"];
  TrueFalseFactory -> TrueFalseEvaluator [style=dashed, label="creates"];

  EssayFactory -> EssayQuestion [style=dashed, label="creates via source"];
  EssayFactory -> EssayRenderer [style=dashed, label="creates"];
  EssayFactory -> EssayEvaluator [style=dashed, label="creates"];

  ProgrammingFactory -> ProgrammingQuestion [style=dashed, label="creates via source"];
  ProgrammingFactory -> ProgrammingRenderer [style=dashed, label="creates"];
  ProgrammingFactory -> ProgrammingEvaluator [style=dashed, label="creates"];
}
