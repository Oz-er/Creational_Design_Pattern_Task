digraph PartD {
  graph [rankdir=TB, bgcolor="white", label="Part D - Question Sourcing Integration", labelloc=t, fontsize=20, fontname="Arial"];
  node [shape=record, fontname="Arial", fontsize=10, style="filled", fillcolor="#f8f8f8", color="#333333"];
  edge [fontname="Arial", fontsize=9, color="#333333"];

  QuestionSource [label="{\<\<interface\>\>\nQuestionSource|+ getQuestion(type: String): Question\l+ getSourceName(): String\l}"];
  BankQuestionSource [label="{BankQuestionSource|- questionBank: QuestionBank\l+ getQuestion(type: String): Question\l+ getSourceName(): String\l}"];
  FakerQuestionSource [label="{FakerQuestionSource|- faker: QuestionFaker\l+ getQuestion(type: String): Question\l+ getSourceName(): String\l}"];
  ManualQuestionSource [label="{ManualQuestionSource|+ getQuestion(type: String): Question\l+ getSourceName(): String\l}"];
  QuestionBank [label="{QuestionBank|- random: Random\l- mcqQuestions: Question[]\l- essayQuestions: Question[]\l- programmingQuestions: Question[]\l- trueFalseQuestions: Question[]\l+ getRandomQuestion(type: String): Question\l}"];
  QuestionFaker [label="{QuestionFaker|+ generateQuestion(type: String): Question\l}"];
  Question [label="{\<\<interface\>\>\nQuestion|+ getType(): String\l+ getPoints(): int\l+ getDifficulty(): String\l}"];

  BankQuestionSource -> QuestionSource [arrowhead=empty, style=dashed];
  FakerQuestionSource -> QuestionSource [arrowhead=empty, style=dashed];
  ManualQuestionSource -> QuestionSource [arrowhead=empty, style=dashed];

  BankQuestionSource -> QuestionBank [label="uses"];
  FakerQuestionSource -> QuestionFaker [label="uses"];

  BankQuestionSource -> Question [style=dashed, label="returns"];
  FakerQuestionSource -> Question [style=dashed, label="returns"];
  ManualQuestionSource -> Question [style=dashed, label="returns"];
  QuestionBank -> Question [style=dashed, label="stores/returns"];
  QuestionFaker -> Question [style=dashed, label="generates"];
}
