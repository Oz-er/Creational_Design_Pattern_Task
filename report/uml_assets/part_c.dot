digraph PartC {
  graph [rankdir=LR, bgcolor="white", label="Part C - Builder Pattern", labelloc=t, fontsize=20, fontname="Arial"];
  node [shape=record, fontname="Arial", fontsize=10, style="filled", fillcolor="#f8f8f8", color="#333333"];
  edge [fontname="Arial", fontsize=9, color="#333333"];

  ExamBuilder [label="{ExamBuilder|- title: String\l- duration: int\l- passingScore: int\l- negativeMarking: boolean\l- questionShuffle: boolean\l- autoSubmit: boolean\l- calculatorAllowed: boolean\l|+ setTitle(title: String): ExamBuilder\l+ setDuration(duration: int): ExamBuilder\l+ setPassingScore(passingScore: int): ExamBuilder\l+ enableNegativeMarking(): ExamBuilder\l+ enableQuestionShuffle(): ExamBuilder\l+ enableAutoSubmit(): ExamBuilder\l+ allowCalculator(): ExamBuilder\l+ build(): ExamConfiguration\l}"];

  ExamConfiguration [label="{ExamConfiguration|- title: String\l- duration: int\l- passingScore: int\l- negativeMarking: boolean\l- questionShuffle: boolean\l- autoSubmit: boolean\l- calculatorAllowed: boolean\l|+ getTitle(): String\l+ getDuration(): int\l+ getPassingScore(): int\l+ hasNegativeMarking(): boolean\l+ hasQuestionShuffle(): boolean\l+ hasAutoSubmit(): boolean\l+ isCalculatorAllowed(): boolean\l+ displayConfiguration(): void\l}"];

  ExamBuilder -> ExamConfiguration [style=dashed, label="builds"];
}
